            "type": "string"
          }
        ]
      },
      {
        "id": "box",
        "label": "Box",
        "context": "ctx-switch",
        "definition": "The single bandwidth-bound machine (an NVIDIA DGX Spark) whose whole configuration the developer switch sets. It has exactly one mode at a time — QUEUE or EXPLORER — because the two residencies cannot co-reside in VRAM. The mode is set externally by a developer, never inferred by the box from its own state.",
        "identity": "box_id",
        "is_aggregate_root": true,
        "attributes": [
          {
            "name": "box_id",
            "type": "string"
          },
          {
            "name": "mode",
            "type": "string"
          },
          {
            "name": "resident_binding",
            "type": "object"
          },
          {
            "name": "thrown_by",
            "type": "string"
          }
        ]
      },
      {
        "id": "execution-run",
        "label": "ExecutionRun",
        "context": "ctx-execution",
        "definition": "One admission of a work-unit into the executor at a specific binding — the unit's execution attempt inside a per-unit ephemeral sandbox. Because the Model axis resets the quality baseline on any binding change, a re-dispatch at a higher binding is a new run (new attribution point), not a continuation: same unit_ref and bundle_hash, new run_id and tier_ran. The run walks the sealed cell-DAG and computes the unit-verdict; its sandbox is destroyed when the run reaches a verdict.",
        "identity": "run_id",
        "is_aggregate_root": true,
        "attributes": [
          {
            "name": "run_id",
            "type": "string"
          },
          {
            "name": "unit_ref",
            "type": "string"
          },
          {
            "name": "bundle_hash",
            "type": "string"
          },
          {
            "name": "tier_ran",
            "type": "string"
          },
          {
            "name": "sandbox_id",
            "type": "string"
          },
          {
            "name": "unit_verdict",
            "type": "string"
          }
        ]
      },
      {
        "id": "cell",
        "label": "Cell",
        "context": "ctx-execution",
        "definition": "The execution primitive beneath a work-unit's bundle, living entirely inside the unit's sealed cell-DAG. Carries intra-unit dependencies only (e.g. test-before-implement); no cross-unit edges ever exist. A cell becomes ready when its in-unit predecessors have passed; the executor batches the ready frontier on the resident binding and gates each cell against a protected oracle. All cells of a well-formed unit require the same binding.",
        "identity": "cell_id",
        "is_aggregate_root": false,
        "attributes": [
          {
            "name": "cell_id",
            "type": "string"
          },
          {
            "name": "run_id",
            "type": "string"
          },
          {
            "name": "binding",
            "type": "object"
          },
          {
            "name": "depends_on",
            "type": "array"
          },
          {
            "name": "cell_verdict",
            "type": "string"
          }
        ]
      },
      {
        "id": "exploration-session",
        "label": "ExplorationSession",
        "context": "ctx-exploration",
        "definition": "A single deep serial run of the local explorer while the box is in EXPLORER. Monopolises VRAM (QUEUE is not running while it is). Latency-tolerant by design: nothing waits on its decode rate. Produces exactly one discovery record on completion; its output is unaccepted by construction and must not enter the graph as code.",
        "identity": "session_id",
        "is_aggregate_root": true,
        "attributes": [
          {
            "name": "session_id",
            "type": "string"
          },
          {
            "name": "prompt",
            "type": "string"
          },
          {
            "name": "resident_binding",
            "type": "object"
          }
        ]
      },
      {
        "id": "discovery-record",
        "label": "DiscoveryRecord",
        "context": "ctx-exploration",
        "definition": "The product of an exploration session: a candidate slice with proposed work-unit boundaries and cells. Candidate structure, not artifact — no computed verdict and no protected oracle backed it. It re-enters engineered mode only by being decomposed into tier-homogeneous work-units, flipped to QUEUE, and dispatched. Never accepted as shippable code.",
        "identity": "record_id",
        "is_aggregate_root": false,
        "attributes": [
          {
            "name": "record_id",
            "type": "string"
          },
          {
            "name": "session_id",
            "type": "string"
          },
          {
            "name": "candidate_slice",
            "type": "object"
          },
          {
            "name": "proposed_units",
            "type": "array"
          }
        ]
      },
      {
        "id": "resident-set",
        "label": "ResidentSet",
        "context": "ctx-serving",
        "definition": "The model bindings currently resident in the box's VRAM under the active mode. A binding may load only if it fits the remaining VRAM budget; eviction frees it. On the Spark, what is resident is what can be batched — so the resident set is the gate on which cell frontiers can run right now.",
        "identity": "set_id",
        "is_aggregate_root": true,
        "attributes": [
          {
            "name": "set_id",
            "type": "string"
          },
          {
            "name": "mode",
            "type": "string"
          },
          {
            "name": "loaded_vram",
            "type": "integer"
          },
          {
            "name": "vram_budget",
            "type": "integer"
          }
        ]
      },
      {
        "id": "work-batch",
        "label": "WorkBatch",
        "context": "ctx-serving",
        "definition": "A batch of unblocked cells, all sharing one resident binding, packed together for a single batched inference pass — the unit of work the serving substrate actually dispatches. A batch is well-formed only if every cell in it requires the resident binding (so the batch is a confound-free inference call) and it is non-empty.",
        "identity": "batch_id",
        "is_aggregate_root": true,
        "attributes": [
          {
            "name": "batch_id",
            "type": "string"
          },
          {
            "name": "binding",
            "type": "object"
          },
          {
            "name": "cell_refs",
            "type": "array"
          },
          {
            "name": "size",
            "type": "integer"
          }
        ]
      },
      {
        "id": "sandbox",
        "label": "Sandbox",
        "context": "ctx-sandbox",
        "definition": "The per-unit ephemeral isolation boundary. Provisioned at admission with a private writable workspace, the frozen bundle mounted read-only, and network restricted to declared destinations; destroyed when the unit reaches a verdict. The sealed cell-DAG runs entirely inside one sandbox — that is why the cell interior is sealed: it is one isolation domain.",
        "identity": "sandbox_id",
        "is_aggregate_root": true,
        "attributes": [
          {
            "name": "sandbox_id",
            "type": "string"
          },
          {
            "name": "unit_ref",
            "type": "string"
          },
          {
            "name": "workspace",
            "type": "string"
          },
          {
            "name": "declared_network",
            "type": "array"
          }
        ]
      },
      {
        "id": "credential-lease",
        "label": "CredentialLease",
        "context": "ctx-sandbox",
        "definition": "Short-lived, least-privilege credentials exchanged from a unit's grant-reference, scoped to the unit's declared effect destinations and bound to the lifetime of its sandbox. The executor never injects a standing secret; authority derives from the unit being executed. Revoked when the sandbox is destroyed.",
        "identity": "lease_id",
        "is_aggregate_root": true,
        "attributes": [
          {
            "name": "lease_id",
            "type": "string"
          },
          {
            "name": "sandbox_id",
            "type": "string"
          },
          {
            "name": "grant_ref",
            "type": "string"
          },
          {
            "name": "ttl_seconds",
            "type": "integer"
          }
        ]
      },
      {
        "id": "verdict-log",
        "label": "VerdictLog",
        "context": "ctx-stream",
        "definition": "The durable, append-only log of emitted VerdictEvents. A verdict is appended at most once (idempotent by bundle_hash); the log is never rewritten. Consumers reconcile pending verdicts into deliverable-done at their own pace — temporal decoupling: a night verdict waits in the log until a morning reader.",
        "identity": "log_id",
        "is_aggregate_root": true,
        "attributes": [
          {
            "name": "log_id",
            "type": "string"
          },
          {
            "name": "appended",
            "type": "integer"
          },
          {
            "name": "reconciled",
            "type": "integer"
          }
        ]
      },
      {
        "id": "oracle-run",
        "label": "OracleRun",
        "context": "ctx-execution",
        "definition": "One execution of a protected oracle gating a cell. The gate may run only against an oracle the cell-worker has no write capability over (ADR-076): a worker that can write its own oracle has no verifier. Confirms the cell-gate's integrity before its pass/fail verdict is trusted.",
        "identity": "oracle_run_id",
        "is_aggregate_root": true,
        "attributes": [
          {
            "name": "oracle_run_id",
            "type": "string"
          },
          {
            "name": "cell_id",
            "type": "string"
          },
          {
            "name": "oracle_ref",
            "type": "string"
          },
          {
            "name": "worker_writable",
            "type": "boolean"
          }
        ]
      },
      {
        "id": "serving-host",
        "label": "ServingHost",
        "context": "ctx-host",
        "definition": "One vLLM inference server materializing a single model binding on the box, launched as a container over SSH and serving an OpenAI-compatible endpoint. It carries the binding it serves (model + served quantization + params — homogeneous, exactly one), the container image, the ssh target it runs on, and the endpoint base URL clients reach once it is ready. Its lifecycle is phased: offline (nothing launched) → launching (container started, not yet answering) → ready (health probe passed, /v1 serving) → retired (container stopped, VRAM freed). A host is the physical counterpart of a resident-set entry; only a ready host can serve cell frontiers, and at most one host is materialized at a time.",
        "identity": "host_id",
        "is_aggregate_root": true,
        "attributes": [
          {
            "name": "host_id",
            "type": "string"
          },
          {
            "name": "mode",
            "type": "string"
          },
          {
            "name": "binding",
            "type": "object"
          },
          {
            "name": "image",
            "type": "string"
          },
          {
            "name": "ssh_target",
            "type": "string"
          },
          {
            "name": "endpoint",
            "type": "string"
          },
          {
            "name": "phase",
            "type": "string"
          }
        ]
      }
    ],
    "value_objects": [],
    "relations": [],
    "invariants": [
      {
        "id": "inv-binding-homogeneity",
        "statement": "A work-unit is well-formed iff all of its cells require the same SPMC model binding. A binding-heterogeneous unit is a decomposition defect and must be rejected at admission, never dispatched into the executor.",
        "context": "ctx-queue",
        "applies_to": "work-unit"
      },
      {
        "id": "inv-only-queued-reorderable",
        "statement": "Only a unit currently in the queued state may be reprioritized. A running, done, failed, or escalated unit is not in the flat priority set and has no position to change.",
        "context": "ctx-queue",
        "applies_to": "work-unit"
      },
      {
        "id": "inv-ladder-exhausted",
        "statement": "A unit may escalate only while its escalation ladder has a higher binding to climb to. When ladder_position has reached the top rung there is no heavier binding to re-dispatch at; the unit halts in failed rather than re-enqueueing.",
        "context": "ctx-execution",
        "applies_to": "work-unit"
      },
      {
        "id": "inv-box-must-be-queue",
        "statement": "The executor may admit a unit only while the box is in QUEUE. The executor and the explorer cannot co-reside in VRAM, so admission outside QUEUE is forbidden by construction.",
        "context": "ctx-execution",
        "applies_to": "execution-run"
      },
      {
        "id": "inv-run-not-admitted",
        "statement": "A unit-verdict may be computed only for a run that has been admitted and has walked its cell-DAG. Computing a verdict for a run not yet admitted is meaningless.",
        "context": "ctx-execution",
        "applies_to": "execution-run"
      },
      {
        "id": "inv-no-verdict-yet",
        "statement": "A VerdictEvent may be emitted only after the run has reached a computed unit-verdict. Emitting before the reduction would publish an unbacked verdict — done must be computed, not claimed.",
        "context": "ctx-execution",
        "applies_to": "execution-run"
      },
      {
        "id": "inv-distinct-mode",
        "statement": "Throwing the switch to the configuration already resident is a no-op and is rejected. Residency flips are expensive; a flip that changes nothing must not pay that cost.",
        "context": "ctx-switch",
        "applies_to": "box"
      },
      {
        "id": "inv-box-must-be-explorer",
        "statement": "A local exploration session may start only while the box is in EXPLORER. The largest resident coder and the batched QUEUE executor cannot co-reside in VRAM.",
        "context": "ctx-exploration",
        "applies_to": "exploration-session"
      },
      {
        "id": "inv-session-not-active",
        "statement": "A discovery record may be produced only by a session that is currently active. A record cannot be emitted before the session has started or after it has already completed.",
        "context": "ctx-exploration",
        "applies_to": "exploration-session"
      },
      {
        "id": "inv-vram-budget",
        "statement": "A binding may be loaded only if its VRAM cost fits the remaining budget under the active mode. The box cannot hold what does not fit; over-commit is forbidden, not handled at runtime.",
        "context": "ctx-serving",
        "applies_to": "resident-set"
      },
      {
        "id": "inv-nothing-resident",
        "statement": "A binding can be evicted only when something is resident. Evicting from an empty set is a no-op error.",
        "context": "ctx-serving",
        "applies_to": "resident-set"
      },
      {
        "id": "inv-batch-homogeneous",
        "statement": "Every cell in a batch must require the resident binding. A batch mixing bindings is a confound and cannot be a single inference call — the same funnel principle as unit homogeneity, at the batch grain.",
        "context": "ctx-serving",
        "applies_to": "work-batch"
      },
      {
        "id": "inv-batch-empty",
        "statement": "A batch must contain at least one cell. An empty batch is a scheduling defect, not a dispatchable unit of work.",
        "context": "ctx-serving",
        "applies_to": "work-batch"
      },
      {
        "id": "inv-batch-not-formed",
        "statement": "Only a formed batch may be dispatched to the model. Dispatching an unformed batch has nothing to send.",
        "context": "ctx-serving",
        "applies_to": "work-batch"
      },
      {
        "id": "inv-undeclared-network",
        "statement": "A sandbox may be provisioned only when the unit's network effects target declared destinations. Reachability beyond the declared boundary is forbidden by construction.",
        "context": "ctx-sandbox",
        "applies_to": "sandbox"
      },
      {
        "id": "inv-no-sandbox",
        "statement": "Only a provisioned sandbox can be torn down. Tearing down a non-existent boundary is a no-op error.",
        "context": "ctx-sandbox",
        "applies_to": "sandbox"
      },
      {
        "id": "inv-lease-needs-sandbox",
        "statement": "Credentials may be leased only for a live sandbox. Authority is bound to the isolation boundary; a lease without one would outlive its scope.",
        "context": "ctx-sandbox",
        "applies_to": "credential-lease"
      },
      {
        "id": "inv-nothing-to-revoke",
        "statement": "Only an active lease can be revoked. Revoking an already-revoked or non-existent lease is a no-op error.",
        "context": "ctx-sandbox",
        "applies_to": "credential-lease"
      },
      {
        "id": "inv-idempotent-append",
        "statement": "A verdict is appended at most once per bundle_hash. The log is append-only and idempotent, so at-least-once emission never duplicates a recorded verdict.",
        "context": "ctx-stream",
        "applies_to": "verdict-log"
      },
      {
        "id": "inv-nothing-to-reconcile",
        "statement": "Reconciliation runs only when there are unreconciled verdicts. Reconciling an empty backlog does nothing.",
        "context": "ctx-stream",
        "applies_to": "verdict-log"
      },
      {
        "id": "inv-oracle-writable",
        "statement": "A cell-gate may run only against an oracle the cell-worker has no write capability over. A worker that can write its own oracle is not verified (ADR-076).",
        "context": "ctx-execution",
        "applies_to": "oracle-run"
      },
      {
        "id": "inv-single-serving-host",
        "statement": "At most one serving host may be materialized at a time: a host may be launched only when none is currently live (offline or retired). The box holds one residency in VRAM; the current host must be retired before another binding is launched. This is the one-residency-at-a-time constraint made physical, giving inv-distinct-mode teeth in hardware.",
        "context": "ctx-host",
        "applies_to": "serving-host"
      },
      {
        "id": "inv-containerized-host",
        "statement": "A serving host may be launched only as a container. The vLLM server always runs containerized on the box — the container is the reproducibility and isolation boundary for the residency. A bare-metal launch request is refused.",
        "context": "ctx-host",
        "applies_to": "serving-host"
      },
      {
        "id": "inv-ready-needs-launch",
        "statement": "A host may be confirmed ready only while it is launching. Readiness is a transition out of the launching phase; confirming a host that is offline, already ready, or retired is a defect.",
        "context": "ctx-host",
        "applies_to": "serving-host"
      },
      {
        "id": "inv-nothing-to-retire",
        "statement": "A host may be retired only when one is live — launching or ready. Retiring from offline or retired has no container to stop and is a no-op error.",
        "context": "ctx-host",
        "applies_to": "serving-host"
      }
    ],
