            "name": "acceptance_class",
            "type": "string"
          },
          {
            "name": "ladder_position",
            "type": "integer"
          },
          {
            "name": "cell_graph",
            "type": "object"
          },
          {
            "name": "environment",
            "type": "object"
          },
          {
            "name": "credential_grant",
            "type": "string"
          },
