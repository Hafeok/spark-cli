    "entities": [
      {
        "id": "work-unit",
        "label": "WorkUnit",
        "context": "ctx-queue",
        "definition": "The schedulable, reorderable, escalatable atom the executor consumes. Frozen and emitted by product dispatch, it crosses the Work-Unit Interface by value with its SPMC bundle inlined and identified by bundle_hash. Its cell_graph is a sealed interior — the executor's concern, never the queue's. Well-formed iff all of its cells require the same model binding (the binding-homogeneity invariant).",
        "identity": "unit_ref",
        "is_aggregate_root": true,
        "attributes": [
          {
            "name": "unit_ref",
            "type": "string"
          },
          {
            "name": "parent_deliverable",
            "type": "string"
          },
          {
            "name": "bundle_hash",
            "type": "string"
          },
          {
            "name": "spmc_bundle",
            "type": "object"
          },
          {
