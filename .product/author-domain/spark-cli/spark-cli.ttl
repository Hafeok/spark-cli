@prefix pf: <https://productframework.org/ns#> .
@prefix d: <https://productframework.org/product/spark-cli#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

d:ctx-queue a pf:BoundedContext ;
  rdfs:label "Work-Unit Queue" .

d:ctx-switch a pf:BoundedContext ;
  rdfs:label "Box Control" .

d:ctx-execution a pf:BoundedContext ;
  rdfs:label "Execution" .

d:ctx-exploration a pf:BoundedContext ;
  rdfs:label "Exploration" .

d:ctx-serving a pf:BoundedContext ;
  rdfs:label "Model Serving" .

d:ctx-sandbox a pf:BoundedContext ;
  rdfs:label "Isolation" .

d:ctx-stream a pf:BoundedContext ;
  rdfs:label "Verdict Stream" .

d:ctx-host a pf:BoundedContext ;
  rdfs:label "Serving Host" .

d:work-unit a pf:Entity ;
  rdfs:label "WorkUnit" ;
  pf:definition "The schedulable, reorderable, escalatable atom the executor consumes. Frozen and emitted by product dispatch, it crosses the Work-Unit Interface by value with its SPMC bundle inlined and identified by bundle_hash. Its cell_graph is a sealed interior — the executor's concern, never the queue's. Well-formed iff all of its cells require the same model binding (the binding-homogeneity invariant)." ;
  pf:inContext d:ctx-queue ;
  pf:isAggregateRoot "true" ;
  pf:identity "unit_ref" ;
  pf:hasAttribute [ pf:attrName "unit_ref" ; pf:attrType "string" ] ;
  pf:hasAttribute [ pf:attrName "parent_deliverable" ; pf:attrType "string" ] ;
  pf:hasAttribute [ pf:attrName "bundle_hash" ; pf:attrType "string" ] ;
  pf:hasAttribute [ pf:attrName "spmc_bundle" ; pf:attrType "object" ] ;
  pf:hasAttribute [ pf:attrName "model_binding" ; pf:attrType "object" ] ;
  pf:hasAttribute [ pf:attrName "tier" ; pf:attrType "string" ] ;
  pf:hasAttribute [ pf:attrName "acceptance_class" ; pf:attrType "string" ] ;
  pf:hasAttribute [ pf:attrName "ladder_position" ; pf:attrType "integer" ] ;
  pf:hasAttribute [ pf:attrName "cell_graph" ; pf:attrType "object" ] ;
  pf:hasAttribute [ pf:attrName "environment" ; pf:attrType "object" ] ;
  pf:hasAttribute [ pf:attrName "credential_grant" ; pf:attrType "string" ] ;
  pf:hasAttribute [ pf:attrName "tool_grants" ; pf:attrType "array" ] ;
  pf:hasAttribute [ pf:attrName "state" ; pf:attrType "string" ] .

d:box a pf:Entity ;
  rdfs:label "Box" ;
  pf:definition "The single bandwidth-bound machine (an NVIDIA DGX Spark) whose whole configuration the developer switch sets. It has exactly one mode at a time — QUEUE or EXPLORER — because the two residencies cannot co-reside in VRAM. The mode is set externally by a developer, never inferred by the box from its own state." ;
  pf:inContext d:ctx-switch ;
  pf:isAggregateRoot "true" ;
  pf:identity "box_id" ;
  pf:hasAttribute [ pf:attrName "box_id" ; pf:attrType "string" ] ;
  pf:hasAttribute [ pf:attrName "mode" ; pf:attrType "string" ] ;
  pf:hasAttribute [ pf:attrName "resident_binding" ; pf:attrType "object" ] ;
  pf:hasAttribute [ pf:attrName "thrown_by" ; pf:attrType "string" ] .

d:execution-run a pf:Entity ;
  rdfs:label "ExecutionRun" ;
  pf:definition "One admission of a work-unit into the executor at a specific binding — the unit's execution attempt inside a per-unit ephemeral sandbox. Because the Model axis resets the quality baseline on any binding change, a re-dispatch at a higher binding is a new run (new attribution point), not a continuation: same unit_ref and bundle_hash, new run_id and tier_ran. The run walks the sealed cell-DAG and computes the unit-verdict; its sandbox is destroyed when the run reaches a verdict." ;
  pf:inContext d:ctx-execution ;
  pf:isAggregateRoot "true" ;
  pf:identity "run_id" ;
  pf:hasAttribute [ pf:attrName "run_id" ; pf:attrType "string" ] ;
  pf:hasAttribute [ pf:attrName "unit_ref" ; pf:attrType "string" ] ;
  pf:hasAttribute [ pf:attrName "bundle_hash" ; pf:attrType "string" ] ;
  pf:hasAttribute [ pf:attrName "tier_ran" ; pf:attrType "string" ] ;
  pf:hasAttribute [ pf:attrName "sandbox_id" ; pf:attrType "string" ] ;
  pf:hasAttribute [ pf:attrName "unit_verdict" ; pf:attrType "string" ] .

d:cell a pf:Entity ;
  rdfs:label "Cell" ;
  pf:definition "The execution primitive beneath a work-unit's bundle, living entirely inside the unit's sealed cell-DAG. Carries intra-unit dependencies only (e.g. test-before-implement); no cross-unit edges ever exist. A cell becomes ready when its in-unit predecessors have passed; the executor batches the ready frontier on the resident binding and gates each cell against a protected oracle. All cells of a well-formed unit require the same binding." ;
  pf:inContext d:ctx-execution ;
  pf:identity "cell_id" ;
  pf:hasAttribute [ pf:attrName "cell_id" ; pf:attrType "string" ] ;
  pf:hasAttribute [ pf:attrName "run_id" ; pf:attrType "string" ] ;
  pf:hasAttribute [ pf:attrName "binding" ; pf:attrType "object" ] ;
  pf:hasAttribute [ pf:attrName "depends_on" ; pf:attrType "array" ] ;
  pf:hasAttribute [ pf:attrName "cell_verdict" ; pf:attrType "string" ] .

d:exploration-session a pf:Entity ;
  rdfs:label "ExplorationSession" ;
  pf:definition "A single deep serial run of the local explorer while the box is in EXPLORER. Monopolises VRAM (QUEUE is not running while it is). Latency-tolerant by design: nothing waits on its decode rate. Produces exactly one discovery record on completion; its output is unaccepted by construction and must not enter the graph as code." ;
  pf:inContext d:ctx-exploration ;
  pf:isAggregateRoot "true" ;
  pf:identity "session_id" ;
  pf:hasAttribute [ pf:attrName "session_id" ; pf:attrType "string" ] ;
  pf:hasAttribute [ pf:attrName "prompt" ; pf:attrType "string" ] ;
  pf:hasAttribute [ pf:attrName "resident_binding" ; pf:attrType "object" ] .

d:discovery-record a pf:Entity ;
  rdfs:label "DiscoveryRecord" ;
  pf:definition "The product of an exploration session: a candidate slice with proposed work-unit boundaries and cells. Candidate structure, not artifact — no computed verdict and no protected oracle backed it. It re-enters engineered mode only by being decomposed into tier-homogeneous work-units, flipped to QUEUE, and dispatched. Never accepted as shippable code." ;
  pf:inContext d:ctx-exploration ;
  pf:identity "record_id" ;
  pf:hasAttribute [ pf:attrName "record_id" ; pf:attrType "string" ] ;
  pf:hasAttribute [ pf:attrName "session_id" ; pf:attrType "string" ] ;
  pf:hasAttribute [ pf:attrName "candidate_slice" ; pf:attrType "object" ] ;
  pf:hasAttribute [ pf:attrName "proposed_units" ; pf:attrType "array" ] .

d:resident-set a pf:Entity ;
  rdfs:label "ResidentSet" ;
  pf:definition "The model bindings currently resident in the box's VRAM under the active mode. A binding may load only if it fits the remaining VRAM budget; eviction frees it. On the Spark, what is resident is what can be batched — so the resident set is the gate on which cell frontiers can run right now." ;
  pf:inContext d:ctx-serving ;
  pf:isAggregateRoot "true" ;
  pf:identity "set_id" ;
  pf:hasAttribute [ pf:attrName "set_id" ; pf:attrType "string" ] ;
  pf:hasAttribute [ pf:attrName "mode" ; pf:attrType "string" ] ;
  pf:hasAttribute [ pf:attrName "loaded_vram" ; pf:attrType "integer" ] ;
  pf:hasAttribute [ pf:attrName "vram_budget" ; pf:attrType "integer" ] .

d:work-batch a pf:Entity ;
  rdfs:label "WorkBatch" ;
  pf:definition "A batch of unblocked cells, all sharing one resident binding, packed together for a single batched inference pass — the unit of work the serving substrate actually dispatches. A batch is well-formed only if every cell in it requires the resident binding (so the batch is a confound-free inference call) and it is non-empty." ;
  pf:inContext d:ctx-serving ;
  pf:isAggregateRoot "true" ;
  pf:identity "batch_id" ;
  pf:hasAttribute [ pf:attrName "batch_id" ; pf:attrType "string" ] ;
  pf:hasAttribute [ pf:attrName "binding" ; pf:attrType "object" ] ;
  pf:hasAttribute [ pf:attrName "cell_refs" ; pf:attrType "array" ] ;
  pf:hasAttribute [ pf:attrName "size" ; pf:attrType "integer" ] .

d:sandbox a pf:Entity ;
  rdfs:label "Sandbox" ;
  pf:definition "The per-unit ephemeral isolation boundary. Provisioned at admission with a private writable workspace, the frozen bundle mounted read-only, and network restricted to declared destinations; destroyed when the unit reaches a verdict. The sealed cell-DAG runs entirely inside one sandbox — that is why the cell interior is sealed: it is one isolation domain." ;
  pf:inContext d:ctx-sandbox ;
  pf:isAggregateRoot "true" ;
  pf:identity "sandbox_id" ;
  pf:hasAttribute [ pf:attrName "sandbox_id" ; pf:attrType "string" ] ;
  pf:hasAttribute [ pf:attrName "unit_ref" ; pf:attrType "string" ] ;
  pf:hasAttribute [ pf:attrName "workspace" ; pf:attrType "string" ] ;
  pf:hasAttribute [ pf:attrName "declared_network" ; pf:attrType "array" ] .

d:credential-lease a pf:Entity ;
  rdfs:label "CredentialLease" ;
  pf:definition "Short-lived, least-privilege credentials exchanged from a unit's grant-reference, scoped to the unit's declared effect destinations and bound to the lifetime of its sandbox. The executor never injects a standing secret; authority derives from the unit being executed. Revoked when the sandbox is destroyed." ;
  pf:inContext d:ctx-sandbox ;
  pf:isAggregateRoot "true" ;
  pf:identity "lease_id" ;
  pf:hasAttribute [ pf:attrName "lease_id" ; pf:attrType "string" ] ;
  pf:hasAttribute [ pf:attrName "sandbox_id" ; pf:attrType "string" ] ;
  pf:hasAttribute [ pf:attrName "grant_ref" ; pf:attrType "string" ] ;
  pf:hasAttribute [ pf:attrName "ttl_seconds" ; pf:attrType "integer" ] .

d:verdict-log a pf:Entity ;
  rdfs:label "VerdictLog" ;
  pf:definition "The durable, append-only log of emitted VerdictEvents. A verdict is appended at most once (idempotent by bundle_hash); the log is never rewritten. Consumers reconcile pending verdicts into deliverable-done at their own pace — temporal decoupling: a night verdict waits in the log until a morning reader." ;
  pf:inContext d:ctx-stream ;
  pf:isAggregateRoot "true" ;
  pf:identity "log_id" ;
  pf:hasAttribute [ pf:attrName "log_id" ; pf:attrType "string" ] ;
  pf:hasAttribute [ pf:attrName "appended" ; pf:attrType "integer" ] ;
  pf:hasAttribute [ pf:attrName "reconciled" ; pf:attrType "integer" ] .

d:oracle-run a pf:Entity ;
  rdfs:label "OracleRun" ;
  pf:definition "One execution of a protected oracle gating a cell. The gate may run only against an oracle the cell-worker has no write capability over (ADR-076): a worker that can write its own oracle has no verifier. Confirms the cell-gate's integrity before its pass/fail verdict is trusted." ;
  pf:inContext d:ctx-execution ;
  pf:isAggregateRoot "true" ;
  pf:identity "oracle_run_id" ;
  pf:hasAttribute [ pf:attrName "oracle_run_id" ; pf:attrType "string" ] ;
  pf:hasAttribute [ pf:attrName "cell_id" ; pf:attrType "string" ] ;
  pf:hasAttribute [ pf:attrName "oracle_ref" ; pf:attrType "string" ] ;
  pf:hasAttribute [ pf:attrName "worker_writable" ; pf:attrType "boolean" ] .

d:serving-host a pf:Entity ;
  rdfs:label "ServingHost" ;
  pf:definition "One vLLM inference server materializing a single model binding on the box, launched as a container over SSH and serving an OpenAI-compatible endpoint. It carries the binding it serves (model + served quantization + params — homogeneous, exactly one), the container image, the ssh target it runs on, and the endpoint base URL clients reach once it is ready. Its lifecycle is phased: offline (nothing launched) → launching (container started, not yet answering) → ready (health probe passed, /v1 serving) → retired (container stopped, VRAM freed). A host is the physical counterpart of a resident-set entry; only a ready host can serve cell frontiers, and at most one host is materialized at a time." ;
  pf:inContext d:ctx-host ;
  pf:isAggregateRoot "true" ;
  pf:identity "host_id" ;
  pf:hasAttribute [ pf:attrName "host_id" ; pf:attrType "string" ] ;
  pf:hasAttribute [ pf:attrName "mode" ; pf:attrType "string" ] ;
  pf:hasAttribute [ pf:attrName "binding" ; pf:attrType "object" ] ;
  pf:hasAttribute [ pf:attrName "image" ; pf:attrType "string" ] ;
  pf:hasAttribute [ pf:attrName "ssh_target" ; pf:attrType "string" ] ;
  pf:hasAttribute [ pf:attrName "endpoint" ; pf:attrType "string" ] ;
  pf:hasAttribute [ pf:attrName "phase" ; pf:attrType "string" ] .

d:inv-binding-homogeneity a pf:Invariant ;
  pf:statement "A work-unit is well-formed iff all of its cells require the same SPMC model binding. A binding-heterogeneous unit is a decomposition defect and must be rejected at admission, never dispatched into the executor." ;
  pf:inContext d:ctx-queue ;
  pf:appliesTo d:work-unit .

d:inv-only-queued-reorderable a pf:Invariant ;
  pf:statement "Only a unit currently in the queued state may be reprioritized. A running, done, failed, or escalated unit is not in the flat priority set and has no position to change." ;
  pf:inContext d:ctx-queue ;
  pf:appliesTo d:work-unit .

d:inv-ladder-exhausted a pf:Invariant ;
  pf:statement "A unit may escalate only while its escalation ladder has a higher binding to climb to. When ladder_position has reached the top rung there is no heavier binding to re-dispatch at; the unit halts in failed rather than re-enqueueing." ;
  pf:inContext d:ctx-execution ;
  pf:appliesTo d:work-unit .

d:inv-box-must-be-queue a pf:Invariant ;
  pf:statement "The executor may admit a unit only while the box is in QUEUE. The executor and the explorer cannot co-reside in VRAM, so admission outside QUEUE is forbidden by construction." ;
  pf:inContext d:ctx-execution ;
  pf:appliesTo d:execution-run .

d:inv-run-not-admitted a pf:Invariant ;
  pf:statement "A unit-verdict may be computed only for a run that has been admitted and has walked its cell-DAG. Computing a verdict for a run not yet admitted is meaningless." ;
  pf:inContext d:ctx-execution ;
  pf:appliesTo d:execution-run .

d:inv-no-verdict-yet a pf:Invariant ;
  pf:statement "A VerdictEvent may be emitted only after the run has reached a computed unit-verdict. Emitting before the reduction would publish an unbacked verdict — done must be computed, not claimed." ;
  pf:inContext d:ctx-execution ;
  pf:appliesTo d:execution-run .

d:inv-distinct-mode a pf:Invariant ;
  pf:statement "Throwing the switch to the configuration already resident is a no-op and is rejected. Residency flips are expensive; a flip that changes nothing must not pay that cost." ;
  pf:inContext d:ctx-switch ;
  pf:appliesTo d:box .

d:inv-box-must-be-explorer a pf:Invariant ;
  pf:statement "A local exploration session may start only while the box is in EXPLORER. The largest resident coder and the batched QUEUE executor cannot co-reside in VRAM." ;
  pf:inContext d:ctx-exploration ;
  pf:appliesTo d:exploration-session .

d:inv-session-not-active a pf:Invariant ;
  pf:statement "A discovery record may be produced only by a session that is currently active. A record cannot be emitted before the session has started or after it has already completed." ;
  pf:inContext d:ctx-exploration ;
  pf:appliesTo d:exploration-session .

d:inv-vram-budget a pf:Invariant ;
  pf:statement "A binding may be loaded only if its VRAM cost fits the remaining budget under the active mode. The box cannot hold what does not fit; over-commit is forbidden, not handled at runtime." ;
  pf:inContext d:ctx-serving ;
  pf:appliesTo d:resident-set .

d:inv-nothing-resident a pf:Invariant ;
  pf:statement "A binding can be evicted only when something is resident. Evicting from an empty set is a no-op error." ;
  pf:inContext d:ctx-serving ;
  pf:appliesTo d:resident-set .

d:inv-batch-homogeneous a pf:Invariant ;
  pf:statement "Every cell in a batch must require the resident binding. A batch mixing bindings is a confound and cannot be a single inference call — the same funnel principle as unit homogeneity, at the batch grain." ;
  pf:inContext d:ctx-serving ;
  pf:appliesTo d:work-batch .

d:inv-batch-empty a pf:Invariant ;
  pf:statement "A batch must contain at least one cell. An empty batch is a scheduling defect, not a dispatchable unit of work." ;
  pf:inContext d:ctx-serving ;
  pf:appliesTo d:work-batch .

d:inv-batch-not-formed a pf:Invariant ;
  pf:statement "Only a formed batch may be dispatched to the model. Dispatching an unformed batch has nothing to send." ;
  pf:inContext d:ctx-serving ;
  pf:appliesTo d:work-batch .

d:inv-undeclared-network a pf:Invariant ;
  pf:statement "A sandbox may be provisioned only when the unit's network effects target declared destinations. Reachability beyond the declared boundary is forbidden by construction." ;
  pf:inContext d:ctx-sandbox ;
  pf:appliesTo d:sandbox .

d:inv-no-sandbox a pf:Invariant ;
  pf:statement "Only a provisioned sandbox can be torn down. Tearing down a non-existent boundary is a no-op error." ;
  pf:inContext d:ctx-sandbox ;
  pf:appliesTo d:sandbox .

d:inv-lease-needs-sandbox a pf:Invariant ;
  pf:statement "Credentials may be leased only for a live sandbox. Authority is bound to the isolation boundary; a lease without one would outlive its scope." ;
  pf:inContext d:ctx-sandbox ;
  pf:appliesTo d:credential-lease .

d:inv-nothing-to-revoke a pf:Invariant ;
  pf:statement "Only an active lease can be revoked. Revoking an already-revoked or non-existent lease is a no-op error." ;
  pf:inContext d:ctx-sandbox ;
  pf:appliesTo d:credential-lease .

d:inv-idempotent-append a pf:Invariant ;
  pf:statement "A verdict is appended at most once per bundle_hash. The log is append-only and idempotent, so at-least-once emission never duplicates a recorded verdict." ;
  pf:inContext d:ctx-stream ;
  pf:appliesTo d:verdict-log .

d:inv-nothing-to-reconcile a pf:Invariant ;
  pf:statement "Reconciliation runs only when there are unreconciled verdicts. Reconciling an empty backlog does nothing." ;
  pf:inContext d:ctx-stream ;
  pf:appliesTo d:verdict-log .

d:inv-oracle-writable a pf:Invariant ;
  pf:statement "A cell-gate may run only against an oracle the cell-worker has no write capability over. A worker that can write its own oracle is not verified (ADR-076)." ;
  pf:inContext d:ctx-execution ;
  pf:appliesTo d:oracle-run .

d:inv-single-serving-host a pf:Invariant ;
  pf:statement "At most one serving host may be materialized at a time: a host may be launched only when none is currently live (offline or retired). The box holds one residency in VRAM; the current host must be retired before another binding is launched. This is the one-residency-at-a-time constraint made physical, giving inv-distinct-mode teeth in hardware." ;
  pf:inContext d:ctx-host ;
  pf:appliesTo d:serving-host .

d:inv-containerized-host a pf:Invariant ;
  pf:statement "A serving host may be launched only as a container. The vLLM server always runs containerized on the box — the container is the reproducibility and isolation boundary for the residency. A bare-metal launch request is refused." ;
  pf:inContext d:ctx-host ;
  pf:appliesTo d:serving-host .

d:inv-ready-needs-launch a pf:Invariant ;
  pf:statement "A host may be confirmed ready only while it is launching. Readiness is a transition out of the launching phase; confirming a host that is offline, already ready, or retired is a defect." ;
  pf:inContext d:ctx-host ;
  pf:appliesTo d:serving-host .

d:inv-nothing-to-retire a pf:Invariant ;
  pf:statement "A host may be retired only when one is live — launching or ready. Retiring from offline or retired has no container to stop and is a no-op error." ;
  pf:inContext d:ctx-host ;
  pf:appliesTo d:serving-host .

d:admit-work-unit a pf:Command ;
  rdfs:label "AdmitWorkUnit" ;
  pf:inContext d:ctx-queue ;
  pf:targets d:work-unit ;
  pf:emits d:work-unit-enqueued ;
  pf:emits d:work-unit-rejected .

d:reprioritize-work-unit a pf:Command ;
  rdfs:label "ReprioritizeWorkUnit" ;
  pf:inContext d:ctx-queue ;
  pf:targets d:work-unit ;
  pf:emits d:work-unit-reprioritized .

d:throw-switch a pf:Command ;
  rdfs:label "ThrowSwitch" ;
  pf:inContext d:ctx-switch ;
  pf:targets d:box ;
  pf:emits d:box-mode-changed .

d:admit-to-executor a pf:Command ;
  rdfs:label "AdmitToExecutor" ;
  pf:inContext d:ctx-execution ;
  pf:targets d:execution-run ;
  pf:emits d:unit-admitted .

d:gate-cell a pf:Command ;
  rdfs:label "GateCell" ;
  pf:inContext d:ctx-execution ;
  pf:targets d:cell ;
  pf:emits d:cell-passed ;
  pf:emits d:cell-failed .

d:compute-unit-verdict a pf:Command ;
  rdfs:label "ComputeUnitVerdict" ;
  pf:inContext d:ctx-execution ;
  pf:targets d:execution-run ;
  pf:emits d:unit-verdict-computed .

d:emit-verdict a pf:Command ;
  rdfs:label "EmitVerdict" ;
  pf:inContext d:ctx-execution ;
  pf:targets d:execution-run ;
  pf:emits d:verdict-emitted .

d:escalate-unit a pf:Command ;
  rdfs:label "EscalateUnit" ;
  pf:inContext d:ctx-execution ;
  pf:targets d:work-unit ;
  pf:emits d:unit-escalated ;
  pf:emits d:unit-halted .

d:start-exploration a pf:Command ;
  rdfs:label "StartExploration" ;
  pf:inContext d:ctx-exploration ;
  pf:targets d:exploration-session ;
  pf:emits d:exploration-started .

d:produce-discovery-record a pf:Command ;
  rdfs:label "ProduceDiscoveryRecord" ;
  pf:inContext d:ctx-exploration ;
  pf:targets d:exploration-session ;
  pf:emits d:discovery-record-produced .

d:load-binding a pf:Command ;
  rdfs:label "LoadBinding" ;
  pf:inContext d:ctx-serving ;
  pf:targets d:resident-set ;
  pf:emits d:binding-loaded .

d:evict-binding a pf:Command ;
  rdfs:label "EvictBinding" ;
  pf:inContext d:ctx-serving ;
  pf:targets d:resident-set ;
  pf:emits d:binding-evicted .

d:form-batch a pf:Command ;
  rdfs:label "FormBatch" ;
  pf:inContext d:ctx-serving ;
  pf:targets d:work-batch ;
  pf:emits d:batch-formed .

d:dispatch-batch a pf:Command ;
  rdfs:label "DispatchBatch" ;
  pf:inContext d:ctx-serving ;
  pf:targets d:work-batch ;
  pf:emits d:batch-dispatched .

d:provision-sandbox a pf:Command ;
  rdfs:label "ProvisionSandbox" ;
  pf:inContext d:ctx-sandbox ;
  pf:targets d:sandbox ;
  pf:emits d:sandbox-provisioned .

d:teardown-sandbox a pf:Command ;
  rdfs:label "TeardownSandbox" ;
  pf:inContext d:ctx-sandbox ;
  pf:targets d:sandbox ;
  pf:emits d:sandbox-destroyed .

d:exchange-credential a pf:Command ;
  rdfs:label "ExchangeCredential" ;
  pf:inContext d:ctx-sandbox ;
  pf:targets d:credential-lease ;
  pf:emits d:credential-leased .

d:revoke-credential a pf:Command ;
  rdfs:label "RevokeCredential" ;
  pf:inContext d:ctx-sandbox ;
  pf:targets d:credential-lease ;
  pf:emits d:credential-revoked .

d:append-verdict a pf:Command ;
  rdfs:label "AppendVerdict" ;
  pf:inContext d:ctx-stream ;
  pf:targets d:verdict-log ;
  pf:emits d:verdict-appended .

d:reconcile-deliverable a pf:Command ;
  rdfs:label "ReconcileDeliverable" ;
  pf:inContext d:ctx-stream ;
  pf:targets d:verdict-log ;
  pf:emits d:deliverable-reconciled .

d:run-gate a pf:Command ;
  rdfs:label "RunGate" ;
  pf:inContext d:ctx-execution ;
  pf:targets d:oracle-run ;
  pf:emits d:gate-confirmed .

d:launch-host a pf:Command ;
  rdfs:label "LaunchHost" ;
  pf:inContext d:ctx-host ;
  pf:targets d:serving-host ;
  pf:emits d:host-launched .

d:confirm-host-ready a pf:Command ;
  rdfs:label "ConfirmHostReady" ;
  pf:inContext d:ctx-host ;
  pf:targets d:serving-host ;
  pf:emits d:host-ready .

d:retire-host a pf:Command ;
  rdfs:label "RetireHost" ;
  pf:inContext d:ctx-host ;
  pf:targets d:serving-host ;
  pf:emits d:host-retired .

d:work-unit-enqueued a pf:Event ;
  rdfs:label "WorkUnitEnqueued" ;
  pf:inContext d:ctx-queue ;
